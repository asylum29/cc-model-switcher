#!/usr/bin/env node

const fs = require("fs");
const path = require("path");

const readline = require("readline");

const SETTINGS_PATH = path.join(process.env.HOME, ".claude", "settings.json");
const PROFILES_DIR = path.join(process.env.HOME, ".cc-model");
const PROFILES_PATH = path.join(PROFILES_DIR, "profiles.json");

const DEFAULT_PROFILES = {
  glm: {
    model: "glm-5.1",
    env: {
      ANTHROPIC_BASE_URL: "https://api.z.ai/api/anthropic",
      API_TIMEOUT_MS: "3000000",
    },
  },
  opus: {
    model: "claude-opus-4-7",
    env: {},
  },
};

function ask(question) {
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  return new Promise((resolve) => rl.question(question, (answer) => {
    rl.close();
    resolve(answer.trim());
  }));
}

async function initProfiles() {
  fs.mkdirSync(PROFILES_DIR, { recursive: true });

  console.log("Первый запуск — настройка профиля GLM 5.1.\n");
  const token = await ask("Введи API-ключ для ZhipuAI: ");

  if (!token) {
    console.error("Токен не указан. Прерываю.");
    process.exit(1);
  }

  DEFAULT_PROFILES.glm.env.ANTHROPIC_AUTH_TOKEN = token;

  fs.writeFileSync(PROFILES_PATH, JSON.stringify(DEFAULT_PROFILES, null, 2) + "\n");
  console.log(`\nКонфиг создан: ${PROFILES_PATH}`);
}

function loadProfiles() {
  if (!fs.existsSync(PROFILES_PATH)) {
    return null;
  }
  return JSON.parse(fs.readFileSync(PROFILES_PATH, "utf-8"));
}

async function ensureProfiles() {
  let profiles = loadProfiles();
  if (!profiles) {
    await initProfiles();
    profiles = loadProfiles();
  }
  return profiles;
}

function readSettings() {
  return JSON.parse(fs.readFileSync(SETTINGS_PATH, "utf-8"));
}

function writeSettings(settings) {
  fs.writeFileSync(SETTINGS_PATH, JSON.stringify(settings, null, 2) + "\n");
}

function status(profiles) {
  const settings = readSettings();
  const model = settings.model || "не указана";
  const baseUrl = settings.env?.ANTHROPIC_BASE_URL || "Anthropic API (по умолчанию)";

  let profileName = "неизвестный";
  for (const [name, profile] of Object.entries(profiles)) {
    if (profile.model === model) {
      profileName = name;
      break;
    }
  }

  console.log(`Модель:     ${model}`);
  console.log(`Профиль:    ${profileName}`);
  console.log(`API:        ${baseUrl}`);
}

function switchProfile(profiles, name) {
  if (!profiles[name]) {
    console.error(
      `Профиль "${name}" не найден. Доступные: ${Object.keys(profiles).join(", ")}`
    );
    process.exit(1);
  }

  const settings = readSettings();
  const profile = profiles[name];

  settings.model = profile.model;

  // Убираем кастомные env-переменные от предыдущего профиля
  delete settings.env.ANTHROPIC_AUTH_TOKEN;
  delete settings.env.ANTHROPIC_BASE_URL;
  delete settings.env.API_TIMEOUT_MS;

  // Добавляем env-переменные нового профиля
  if (Object.keys(profile.env).length > 0) {
    Object.assign(settings.env, profile.env);
  }

  writeSettings(settings);
  console.log(`Переключено на: ${profile.model} (${name})`);
  console.log("Перезапусти Claude Code для применения изменений.");
}

function listProfiles(profiles) {
  const settings = readSettings();
  const currentModel = settings.model;

  console.log("Доступные профили:\n");
  for (const [name, profile] of Object.entries(profiles)) {
    const active = profile.model === currentModel ? " <-- активный" : "";
    const api =
      profile.env?.ANTHROPIC_BASE_URL || "Anthropic API (по умолчанию)";
    console.log(`  ${name.padEnd(6)} ${profile.model.padEnd(20)} ${api}${active}`);
  }
}

// Main
(async () => {
  const [,, command, arg] = process.argv;

  if (command === "help" || !command) {
    console.log("cc-model — переключатель моделей для Claude Code\n");
    console.log("Команды:");
    console.log("  switch <profile>  Переключить модель (алиас: use)");
    console.log("  status            Показать текущую модель (алиас: current)");
    console.log("  list              Список профилей (алиас: profiles)");
    console.log("  help              Показать эту справку");
    console.log("\nПримеры:");
    console.log("  cc-model switch opus");
    console.log("  cc-model status");
    console.log("\nПосле switch перезапусти Claude Code.");
    return;
  }

  const profiles = await ensureProfiles();

  switch (command) {
    case "switch":
    case "use":
      if (!arg) {
        console.error("Укажи профиль: cc-model switch <name>");
        process.exit(1);
      }
      switchProfile(profiles, arg);
      break;
    case "status":
    case "current":
      status(profiles);
      break;
    case "list":
    case "profiles":
      listProfiles(profiles);
      break;
  }
})();
