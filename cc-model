#!/usr/bin/env node

const fs = require("fs");
const path = require("path");

const readline = require("readline");

const SETTINGS_PATH = path.join(process.env.HOME, ".claude", "settings.json");
const PROFILES_DIR = path.join(process.env.HOME, ".cc-model");
const PROFILES_PATH = path.join(PROFILES_DIR, "profiles.json");

const MANAGED_ENV_KEYS = [
  "ANTHROPIC_API_KEY",
  "ANTHROPIC_AUTH_TOKEN",
  "ANTHROPIC_BASE_URL",
  "API_TIMEOUT_MS",
  "HTTPS_PROXY",
  "HTTP_PROXY",
];

const DEFAULT_PROFILES = {
  glm: {
    model: "glm-5.1",
    env: {
      ANTHROPIC_BASE_URL: "https://api.z.ai/api/anthropic",
      API_TIMEOUT_MS: "3000000",
    },
  },
  opus: {
    model: "claude-opus-4-7",
  },
};

function ask(question) {
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  return new Promise((resolve) => rl.question(question, (answer) => {
    rl.close();
    resolve(answer.trim());
  }));
}

async function initProfiles() {
  fs.mkdirSync(PROFILES_DIR, { recursive: true });

  console.log("First run — setting up GLM 5.1 profile.\n");
  const token = await ask("Enter ZhipuAI API key: ");

  if (!token) {
    console.error("No API key provided. Aborting.");
    process.exit(1);
  }

  DEFAULT_PROFILES.glm.env.ANTHROPIC_AUTH_TOKEN = token;

  fs.writeFileSync(PROFILES_PATH, JSON.stringify(DEFAULT_PROFILES, null, 2) + "\n");
  console.log(`\nConfig created: ${PROFILES_PATH}`);
}

function loadProfiles() {
  if (!fs.existsSync(PROFILES_PATH)) {
    return null;
  }
  return JSON.parse(fs.readFileSync(PROFILES_PATH, "utf-8"));
}

async function ensureProfiles() {
  let profiles = loadProfiles();
  if (!profiles) {
    await initProfiles();
    profiles = loadProfiles();
  }
  return profiles;
}

function readSettings() {
  return JSON.parse(fs.readFileSync(SETTINGS_PATH, "utf-8"));
}

function writeSettings(settings) {
  fs.writeFileSync(SETTINGS_PATH, JSON.stringify(settings, null, 2) + "\n");
}

function status(profiles) {
  const settings = readSettings();
  const model = settings.model || "not set";
  const baseUrl = settings.env?.ANTHROPIC_BASE_URL || "Anthropic API (default)";
  const proxy = settings.env?.HTTPS_PROXY || settings.env?.HTTP_PROXY;

  let profileName = "unknown";
  for (const [name, profile] of Object.entries(profiles)) {
    if (profile.model === model) {
      profileName = name;
      break;
    }
  }

  console.log(`Model:      ${model}`);
  console.log(`Profile:    ${profileName}`);
  console.log(`API:        ${baseUrl}`);
  if (proxy) {
    console.log(`Proxy:      ${proxy}`);
  }
}

function switchProfile(profiles, name) {
  if (!profiles[name]) {
    console.error(
      `Profile "${name}" not found. Available: ${Object.keys(profiles).join(", ")}`
    );
    process.exit(1);
  }

  const settings = readSettings();
  const profile = profiles[name];

  settings.model = profile.model;

  // Ensure settings.env exists
  if (!settings.env) {
    settings.env = {};
  }

  // Remove all managed env vars from previous profile
  for (const key of MANAGED_ENV_KEYS) {
    delete settings.env[key];
  }

  // Add env vars from new profile (if any)
  const env = profile.env || {};
  if (Object.keys(env).length > 0) {
    Object.assign(settings.env, env);
  }

  writeSettings(settings);
  console.log(`Switched to: ${profile.model} (${name})`);
  console.log("Restart Claude Code to apply changes.");
}

function listProfiles(profiles) {
  const settings = readSettings();
  const currentModel = settings.model;

  console.log("Available profiles:\n");
  for (const [name, profile] of Object.entries(profiles)) {
    const active = profile.model === currentModel ? " <-- active" : "";
    const api =
      profile.env?.ANTHROPIC_BASE_URL || "Anthropic API (default)";
    const proxy = profile.env?.HTTPS_PROXY || profile.env?.HTTP_PROXY;
    const proxyStr = proxy ? ` (proxy: ${proxy})` : "";
    console.log(`  ${name.padEnd(6)} ${profile.model.padEnd(20)} ${api}${proxyStr}${active}`);
  }
}

// Main
(async () => {
  const [,, command, arg] = process.argv;

  if (command === "help" || !command) {
    console.log("cc-model — Claude Code model switcher\n");
    console.log("Commands:");
    console.log("  switch <profile>  Switch model (alias: use)");
    console.log("  status            Show current model (alias: current)");
    console.log("  list              List profiles (alias: profiles)");
    console.log("  help              Show this help");
    console.log("\nExamples:");
    console.log("  cc-model switch opus");
    console.log("  cc-model status");
    console.log("\nRestart Claude Code after switching.");
    return;
  }

  const profiles = await ensureProfiles();

  switch (command) {
    case "switch":
    case "use":
      if (!arg) {
        console.error("Specify a profile: cc-model switch <name>");
        process.exit(1);
      }
      switchProfile(profiles, arg);
      break;
    case "status":
    case "current":
      status(profiles);
      break;
    case "list":
    case "profiles":
      listProfiles(profiles);
      break;
  }
})();
